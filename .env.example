# Supabase Configuration
# Get these values from https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Vercel (auto-managed, não editar)
# VERCEL_URL=https://backstage-pro.vercel.app

# Supabase Edge Functions (Dashboard → Edge Functions → Secrets)
# GEMINI_API_KEY=...                  # AI Mentor — GRÁTIS em aistudio.google.com/apikey (opcional)
# GOOGLE_CLIENT_ID=...                # Google Calendar OAuth
# GOOGLE_CLIENT_SECRET=...            # Google Calendar OAuth
# BACKSTAGE_APP_URL=https://backstage-pro-beta.vercel.app
