{
  "name": "backstage-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:full": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "push:setup-cron": "node scripts/setup-push-cron.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node server/index.js",
    "supabase:start": "npx --yes supabase@latest start",
    "supabase:stop": "npx --yes supabase@latest stop",
    "supabase:status": "npx --yes supabase@latest status",
    "db:reset": "npx --yes supabase@latest db reset",
    "db:push": "npx --yes supabase@latest db push",
    "supabase:auth-push": "powershell -ExecutionPolicy Bypass -File ./scripts/push-supabase-auth-config.ps1",
    "db:seed-demo": "node scripts/seed-demo-user.mjs",
    "db:backfill-locations": "node scripts/backfill-event-locations.mjs",
    "db:audit-orphan-events": "node scripts/audit-orphan-events.mjs",
    "db:audit-companies": "node scripts/audit-companies.mjs",
    "db:audit": "pnpm db:audit-orphan-events && pnpm db:audit-companies",
    "db:backfill-companies": "node scripts/backfill-companies-from-clients.mjs",
    "db:backfill-company-logos": "node scripts/backfill-company-logos-from-clients.mjs",
    "db:enrich-companies": "node scripts/enrich-companies-from-api.mjs",
    "db:backfill-orphan-events": "node scripts/backfill-orphan-event-clients.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke",
    "test:e2e:regression": "playwright test e2e/regression",
    "test:e2e:prod": "playwright test -c playwright.prod.config.js",
    "git:backup": "node .cursor/hooks/auto-save-push.mjs"
  },
